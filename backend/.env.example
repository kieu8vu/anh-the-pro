# .env.example — Copy thành .env và điền giá trị thật
# (ĐỪNG commit file .env lên GitHub!)

# Cổng mặc định khi chạy local
PORT=8000

# Giới hạn kích thước upload (MB)
MAX_FILE_SIZE_MB=10

# CORS origins cho phép (production — thay bằng domain thật)
# ALLOWED_ORIGINS=https://anh-the-pro.netlify.app,https://yourdomain.com
ALLOWED_ORIGINS=*
